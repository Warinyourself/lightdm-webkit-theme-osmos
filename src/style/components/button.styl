.app-button
  padding 6px 16px
  border-radius 999px
  border 1px solid var(--glass-border)
  cursor pointer
  background var(--glass-bg-active)
  backdrop-filter var(--glass-blur)
  -webkit-backdrop-filter var(--glass-blur)
  box-shadow var(--glass-shadow), inset 0 1px 0 rgba(255, 255, 255, 0.1)
  display flex
  color white
  align-items center
  justify-content center
  transition: .25s background, .25s border, .25s color, .25s box-shadow
  &:hover
    background rgba(255, 255, 255, .22)
    border-color var(--glass-border-active)
  &:focus
    border-color var(--glass-border-active)
    outline none
    box-shadow 0 0 0 3px rgba(255, 255, 255, .15)

.app-button--block
  display: flex;
  flex: 1 0 auto;
  width: 100%;

.app-button__loader
  display flex
  .spin
    animation spin 0.8s linear infinite

@keyframes spin
  to
    transform rotate(360deg)

.app-button--fab
  padding 4px
  border-radius 12px
  cursor pointer
  background var(--glass-bg)
  border 1px solid var(--glass-border)
  backdrop-filter var(--glass-blur)
  -webkit-backdrop-filter var(--glass-blur)
  box-shadow var(--glass-shadow), inset 0 1px 0 rgba(255, 255, 255, 0.08)
  width 40px
  transition border-radius .15s, background .25s, border-color .25s
  height 40px
  &:hover
    background var(--glass-bg-active)
    border-color var(--glass-border-active)
    svg
      color white
  svg
    color var(--color-unfocus)
    display block
    transition 0.15s
    margin 0

